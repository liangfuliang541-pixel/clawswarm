# ClawSwarm 环境变量模板
# 复制此文件为 .env，然后填入实际值

# ── 基本配置 ──────────────────────────────────────────────────────────────
CLAWSWARM_BASE_DIR=/data/swarm
CLAWSWARM_ENV=production          # development / staging / production
CLAWSWARM_SERVICE_NAME=clawswarm

# ── LLM 配置 ──────────────────────────────────────────────────────────────
# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Ollama (本地模型)
OLLAMA_BASE_URL=http://localhost:11434

# 默认 LLM
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o-mini

# ── OpenTelemetry 可观察性 ──────────────────────────────────────────────
CLAWSWARM_OTEL_ENABLED=false
CLAWSWARM_OTEL_ENDPOINT=http://localhost:4317    # Jaeger/Tempo OTLP gRPC
CLAWSWARM_OTEL_CONSOLE=false                     # 打印到 stdout

# ── WebSocket Event Server ───────────────────────────────────────────────
CLAWSWARM_WS_HOST=0.0.0.0
CLAWSWARM_WS_PORT=8765
CLAWSWARM_METRICS_INTERVAL=10

# ── HITL (Human-in-the-Loop) ─────────────────────────────────────────────
# 审批策略: always_approve / always_require / by_priority
HITL_POLICY_MODE=always_require
HITL_PRIORITY_THRESHOLD=5

# Webhook URL（审批通知）
CLAWSWARM_HITL_WEBHOOK=

# ── OpenClaw 集成 ─────────────────────────────────────────────────────────
# OpenClaw Gateway URL（用于 sessions_spawn 等）
OPENCLAW_GATEWAY_URL=http://localhost:19000
OPENCLAW_GATEWAY_TOKEN=

# ── 集群配置 ──────────────────────────────────────────────────────────────
# 节点心跳超时（秒）
OFFLINE_THRESHOLD_SEC=30

# 任务超时（秒）
TASK_TIMEOUT_SEC=300

# Stale 任务恢复（秒）
STALE_THRESHOLD_SEC=600
